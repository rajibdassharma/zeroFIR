# zeroFIR backend .env — copy to backend/.env before starting the app.
# Every var is prefixed ZFIR_ (Pydantic Settings env_prefix).
# Backend REFUSES to start if ZFIR_JWT_SECRET is missing / default / <32 chars.

# ── Database ───────────────────────────────────────────────────────
ZFIR_DB_HOST=localhost
ZFIR_DB_PORT=3306
ZFIR_DB_USER=root
ZFIR_DB_PASSWORD=
ZFIR_DB_NAME=zerofir

# ── JWT ────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
# (or python -c "import secrets; print(secrets.token_hex(32))")
ZFIR_JWT_SECRET=REPLACE-ME-WITH-64-CHAR-HEX
ZFIR_JWT_ALGORITHM=HS256
ZFIR_JWT_EXPIRE_MINUTES=480

# ── CORS ───────────────────────────────────────────────────────────
ZFIR_CORS_ORIGINS=http://localhost:5173

# ── Docs ───────────────────────────────────────────────────────────
# true on prod so /docs and /openapi.json don't leak the API surface
ZFIR_DISABLE_DOCS=false

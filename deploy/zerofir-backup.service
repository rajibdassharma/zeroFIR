[Unit]
Description=zeroFIR — daily MySQL backup of zerofir
After=mysql.service
Requires=mysql.service

[Service]
Type=oneshot
User=zerofir
Group=zerofir
WorkingDirectory=/opt/zerofir
ExecStart=/opt/zerofir/deploy/backup-db.sh

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/opt/zerofir/backups

StandardOutput=journal
StandardError=journal
